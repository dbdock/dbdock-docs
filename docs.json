{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "DBdock",
  "logo": {
    "light": "/images/logo-primary.png",
    "dark": "/images/logo-white.png"
  },
  "css": [
    "global.css"
  ],
  "colors": {
    "primary": "#23517c",
    "light": "#4d82b8",
    "dark": "#16324d"
  },
  "favicon": "/images/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "index",
              "get-started/installation",
              "get-started/quickstart"
            ]
          },
          {
            "group": "Core",
            "pages": [
              "core/concepts",
              "core/configuration",
              "core/security"
            ]
          },
          {
            "group": "CLI Reference",
            "pages": [
              "cli/overview",
              "cli/init",
              "cli/backup",
              "cli/restore",
              "cli/copydb",
              "cli/list",
              "cli/delete",
              "cli/cleanup",
              "cli/schedule",
              "cli/status",
              "cli/test",
              "cli/migrate-config"
            ]
          },
          {
            "group": "Migration",
            "pages": [
              "migration/overview",
              "migration/analyze",
              "migration/migrate",
              "migration/schema-mapping",
              "migration/dry-run",
              "migration/incremental"
            ]
          },
          {
            "group": "Storage Providers",
            "pages": [
              "storage/overview",
              "storage/local",
              "storage/s3",
              "storage/r2",
              "storage/cloudinary",
              "storage/deletion-safety"
            ]
          },
          {
            "group": "Alerts & Automation",
            "pages": [
              "alerts/overview",
              "alerts/scheduling",
              "alerts/email",
              "alerts/slack",
              "alerts/webhooks"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/staging-refresh",
              "guides/key-rotation",
              "guides/retention-strategies",
              "guides/production-checklist"
            ]
          },
          {
            "group": "SDK",
            "pages": [
              "sdk/overview",
              "sdk/creating-backups",
              "sdk/listing-backups",
              "sdk/scheduling",
              "sdk/alerts"
            ]
          },
          {
            "group": "Help",
            "pages": [
              "help/troubleshooting",
              "help/faq",
              "help/changelog"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "NPM",
          "href": "https://www.npmjs.com/package/dbdock",
          "icon": "npm"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/dbdock/dbdock",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://github.com/dbdock/dbdock/issues"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/dbdock/dbdock"
    }
  }
}
