{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "DBDock",
  "description": "DBDock is a database toolkit for backups, restores, database copies, and cross-database migrations — as an open-source CLI and a managed cloud dashboard, kept in sync.",
  "logo": {
    "light": "/images/logo-primary.png",
    "dark": "/images/logo-white.png"
  },
  "css": [
    "global.css"
  ],
  "colors": {
    "primary": "#23517c",
    "light": "#4d82b8",
    "dark": "#16324d"
  },
  "favicon": "/images/favicon.png",
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "og:site_name": "DBDock Documentation",
      "og:type": "website",
      "twitter:card": "summary_large_image"
    }
  },
  "redirects": [
    {
      "source": "/core/security",
      "destination": "/security/overview"
    }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "index",
              "get-started/what-is-dbdock",
              "get-started/quickstart-cloud",
              "get-started/quickstart",
              "get-started/installation"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "core/concepts",
              "core/configuration"
            ]
          },
          {
            "group": "DBDock Cloud",
            "pages": [
              "cloud/overview",
              "cloud/connections",
              "cloud/backups",
              "cloud/storage",
              "cloud/schedules",
              "cloud/teams",
              "cloud/mcp",
              "cloud/billing"
            ]
          },
          {
            "group": "Cloud Sync",
            "pages": [
              "cloud-sync/overview",
              "cloud-sync/authentication",
              "cloud-sync/sync",
              "cloud-sync/data-handling"
            ]
          },
          {
            "group": "Security",
            "pages": [
              "security/overview",
              "security/encryption",
              "security/cloud",
              "security/key-management"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/staging-refresh",
              "guides/key-rotation",
              "guides/retention-strategies",
              "guides/production-checklist"
            ]
          },
          {
            "group": "Help",
            "pages": [
              "help/troubleshooting",
              "help/faq",
              "help/changelog"
            ]
          }
        ]
      },
      {
        "tab": "CLI Reference",
        "groups": [
          {
            "group": "CLI",
            "pages": [
              "cli/overview",
              "cli/init",
              "cli/backup",
              "cli/restore",
              "cli/copydb",
              "cli/list",
              "cli/delete",
              "cli/cleanup",
              "cli/schedule",
              "cli/status",
              "cli/test",
              "cli/migrate-config"
            ]
          },
          {
            "group": "Cloud Sync (CLI)",
            "pages": [
              "cli/login",
              "cli/sync",
              "cli/open"
            ]
          },
          {
            "group": "Storage Providers",
            "pages": [
              "storage/overview",
              "storage/local",
              "storage/s3",
              "storage/r2",
              "storage/cloudinary",
              "storage/deletion-safety"
            ]
          },
          {
            "group": "Migration",
            "pages": [
              "migration/overview",
              "migration/analyze",
              "migration/migrate",
              "migration/schema-mapping",
              "migration/dry-run",
              "migration/incremental"
            ]
          },
          {
            "group": "Alerts & Automation",
            "pages": [
              "alerts/overview",
              "alerts/scheduling",
              "alerts/email",
              "alerts/slack",
              "alerts/webhooks"
            ]
          }
        ]
      },
      {
        "tab": "SDK",
        "groups": [
          {
            "group": "SDK",
            "pages": [
              "sdk/overview",
              "sdk/creating-backups",
              "sdk/listing-backups",
              "sdk/scheduling",
              "sdk/alerts"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://dbdock.xyz",
          "icon": "gauge"
        },
        {
          "anchor": "NPM",
          "href": "https://www.npmjs.com/package/dbdock",
          "icon": "npm"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/dbdock/dbdock",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://github.com/dbdock/dbdock/issues"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Go to Dashboard",
      "href": "https://dbdock.xyz"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/dbdock/dbdock",
      "website": "https://dbdock.xyz"
    }
  }
}
